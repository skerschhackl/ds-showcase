  {
    "id": "analytics-delete-action",
    "prompt": "Build an analytics dashboard with table rows and delete functionality via action button.",
    "output": {
      "title": "Analytics Dashboard",
      "summary": "Review adoption signals and delete queued rows from the analytics table.",
      "components": ["Alert", "Card", "Select", "Table", "Badge", "Button"],
      "unsupported": [],
      "screen": {
        "alert": { "tone": "neutral", "title": "Analytics ready", "body": "Table rows include explicit delete actions." },
        "metrics": [
          { "label": "Activation", "value": "68%", "progress": 68 },
          { "label": "Weekly users", "value": "12.8k", "progress": 82 }
        ],
        "fields": [
          { "label": "Segment", "kind": "select", "options": ["All users", "New admins", "Enterprise"] }
        ],
        "table": {
          "columns": ["Segment", "Signal", "Action"],
          "rows": [
            ["New admins", { "text": "High intent", "tone": "success" }, { "action": "Delete", "variant": "secondary" }],
            ["Dormant teams", { "text": "Usage down", "tone": "warning" }, { "action": "Delete", "variant": "secondary" }]
          ]
        },
        "primaryAction": "Refresh analytics",
        "secondaryAction": "Save dashboard"
      }
    },
    "expect": {
      "requiredComponents": ["Card", "Select", "Table", "Button"],
      "forbiddenComponents": ["Modal"],
      "requiresTokenEvidence": ["surface", "border", "spacing", "focus", "status"],
      "requiresVisibleLabels": true,
      "requiresStatusText": true,
      "requiresTableStructure": true,
      "requiresActionLabels": true,
      "rejectsUnsupportedRendered": true,
      "promptTerms": ["analytics", "dashboard", "delete"]
    }
  },
  {
    "id": "modal-gap",
    "prompt": "Create a team management screen with invite modal.",
    "output": {
      "title": "Team Management",
