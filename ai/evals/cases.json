[
  {
    "id": "billing-custom-heading-download",
    "prompt": "Generate a billing settings page for a B2B workspace using approved components. It should have a heading at the top saying 'my bills' and featuring a button to download all entries.",
    "output": {
      "title": "My Bills",
      "summary": "Manage B2B workspace billing entries and download all invoice rows.",
      "components": ["Alert", "Card", "Input", "Select", "Table", "Badge", "Button"],
      "unsupported": [],
      "screen": {
        "alert": { "tone": "success", "title": "Billing ready", "body": "Billing entries are ready to review and download." },
        "metrics": [
          { "label": "Current plan", "value": "Growth" },
          { "label": "Billing entries", "value": "3" }
        ],
        "fields": [
          { "label": "Billing email", "kind": "input", "placeholder": "finance@example.com" },
          { "label": "Plan", "kind": "select", "options": ["Starter", "Growth", "Enterprise"] }
        ],
        "table": {
          "columns": ["Entry", "Date", "Status", "Amount"],
          "rows": [
            ["INV-1042", "May 01", { "text": "Paid", "tone": "success" }, "$240.00"],
            ["INV-1038", "Apr 01", { "text": "Paid", "tone": "success" }, "$240.00"]
          ]
        },
        "primaryAction": "Save billing",
        "secondaryAction": "Download all entries"
      }
    },
    "expect": {
      "requiredComponents": ["Input", "Select", "Table", "Badge", "Button"],
      "forbiddenComponents": ["Modal", "Chart"],
      "requiresTokenEvidence": ["surface", "border", "spacing", "focus", "status"],
      "requiresVisibleLabels": true,
      "requiresStatusText": true,
      "requiresTableStructure": true,
      "requiresActionLabels": true,
      "rejectsUnsupportedRendered": true,
      "promptTerms": ["bills", "download", "entries"]
    }
  },
