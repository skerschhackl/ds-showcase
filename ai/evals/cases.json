          { "label": "Members", "value": "12" },
          { "label": "Pending invites", "value": "3" }
        ],
        "fields": [
          { "label": "Invite email", "kind": "input", "placeholder": "name@example.com" },
          { "label": "Default role", "kind": "select", "options": ["Viewer", "Member", "Admin"] }
        ],
        "table": {
          "columns": ["Name", "Role", "Status"],
          "rows": [
            ["Ari Lee", "Admin", { "text": "Active", "tone": "success" }],
            ["Mina Patel", "Member", { "text": "Invited", "tone": "primary" }]
          ]
        },
        "primaryAction": "Send invite",
        "secondaryAction": "Request modal component"
      }
    },
    "expect": {
      "requiredComponents": ["Alert", "Input", "Table"],
      "forbiddenComponents": ["Modal"],
      "requiresUnsupportedFlag": ["Modal"],
      "requiresTokenEvidence": ["border", "spacing", "focus", "status"],
      "requiresVisibleLabels": true,
      "requiresStatusText": true,
      "requiresTableStructure": true,
      "requiresActionLabels": true,
      "rejectsUnsupportedRendered": true,
      "promptTerms": ["team", "invite", "modal"]
    }
  }
